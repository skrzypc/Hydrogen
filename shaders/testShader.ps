
struct PassData
{
    float4 colorTint;
};

ConstantBuffer<PassData> g_passData : register(b1, space0);

struct PSInput
{
    float4 position : SV_Position;
    float2 uv       : TEXCOORD0;
};

float4 main(PSInput input) : SV_Target0
{
    return float4(input.uv, 0.0f, 1.0f) * g_passData.colorTint;
}